# 511.org API key — request one at https://511.org/open-data/token
TRANSIT_511_API_KEY=your_api_key_here

# Mapbox public access token — create one at https://account.mapbox.com/
# Embedded into the bundle at build time (VITE_ prefix). Required for the
# /map page; without it the map shows a configuration-help screen.
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Set to "true" to serve /sample/ data instead of hitting the live 511 API.
# Useful for UI development without needing a real API key.
USE_SAMPLE_DATA=false
